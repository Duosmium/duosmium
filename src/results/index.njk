---
title: Triosmium Results | Triosmium — Improving Science Olympiad scoring and results
description: Find the overall standings and event scores for thousands of Science Olympiad tournaments!

manifest: /results/manifest.json
layout: layout.njk
---
{% block head %}
    <link rel="preload" href="/results/tournaments.json" as="fetch" crossorigin="anonymous">
{% endblock %}

<div class="announcement">
            We've just launched the Trisomium Facebook! Follow us at <a href="https://www.instagram.com/duosmium.scioly/">@duosmium.scioly</a> for exciting Triosmium news, april fools jokes, and tournament results!
            <button type="button" class="close-announcement" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<div id="beta-paywall-overlay" aria-hidden="true" style="display: none;">
    <div id="beta-paywall-card" role="dialog" aria-modal="true" aria-labelledby="beta-paywall-title">
        <h2 id="beta-paywall-title">Triosmium Early Access</h2>
        <p>Triosmium: Your free trial of Duosmium has expired. Upgrade to Triosmium for $0.00/67 days to continue.</p>
        <button type="button" id="beta-paywall-continue" class="btn btn-primary">Continue for Free</button>
    </div>
</div>

<div class="search-wrapper" id="top">
    <!-- The MIT License (MIT)
        Copyright (c) 2016 Tim Holman
        http://tholman.com/github-corners/
        BEGIN -->
    <a href="https://github.com/Duosmium/duosmium" class="github-corner" aria-label="View source on GitHub">
        <svg width="80" height="80" viewBox="0 0 250 250" style="fill:#06021C; color:#fafafa; position: absolute; top: 0; border: 0; right: 0;" aria-hidden="true">
            <path d="M0,0 L115,115 L130,115 L142,142 L250,250 L250,0 Z"></path>
            <path d="M128.3,109.0 C113.8,99.7 119.0,89.6 119.0,89.6 C122.0,82.7 120.5,78.6 120.5,78.6 C119.2,72.0 123.4,76.3 123.4,76.3 C127.3,80.9 125.5,87.3 125.5,87.3 C122.9,97.6 130.6,101.9 134.4,103.2" fill="currentColor" style="transform-origin: 130px 106px;" class="octo-arm"></path>
            <path d="M115.0,115.0 C114.9,115.1 118.7,116.5 119.8,115.4 L133.7,101.6 C136.9,99.2 139.9,98.4 142.2,98.6 C133.8,88.0 127.5,74.4 143.8,58.0 C148.5,53.4 154.0,51.2 159.7,51.0 C160.3,49.4 163.2,43.6 171.4,40.1 C171.4,40.1 176.1,42.5 178.8,56.2 C183.1,58.6 187.2,61.8 190.9,65.4 C194.5,69.0 197.7,73.2 200.1,77.6 C213.8,80.2 216.3,84.9 216.3,84.9 C212.7,93.1 206.9,96.0 205.4,96.6 C205.1,102.4 203.0,107.8 198.3,112.5 C181.9,128.9 168.3,122.5 157.7,114.1 C157.9,116.9 156.7,120.9 152.7,124.9 L141.0,136.5 C139.8,137.7 141.6,141.9 141.8,141.8 Z" fill="currentColor" class="octo-body"></path>
        </svg>
    </a>
    <style>
        .github-corner:hover .octo-arm {
            animation: octocat-wave 560ms ease-in-out;
        }

        @keyframes octocat-wave {
            0%,
            100% {
                transform: rotate(0);
            }
            20%,
            60% {
                transform: rotate(-25deg);
            }
            40%,
            80% {
                transform: rotate(10deg);
            }
        }

        @media (max-width: 500px) {
            .github-corner:hover .octo-arm {
                animation: none;
            }

            .github-corner .octo-arm {
                animation: octocat-wave 560ms ease-in-out;
            }
        }
    </style>
    <style>
        .school-search-bar {
            position: relative;
            width: 100%;
            max-width: none;
            margin: 0 0 1rem;
        }
        .results-sidebar {
            flex: 0 0 420px !important;
            width: 420px !important;
            max-width: 420px !important;
        }
        @media (max-width: 767.98px) {
            .results-sidebar {
                flex: 1 1 auto;
                width: auto !important;
                max-width: none;
            }
        }
        .school-input-wrapper {
            position: relative;
            padding-top: 16px;
        }
        div.search-wrapper .school-input-wrapper > label {
            position: absolute !important;
            top: 20px;
            left: 0;
            display: flex !important;
            align-items: center;
            gap: 2px;
            font-size: 14px !important;
            line-height: 1.5 !important;
            color: rgba(0,0,0,0.54);
            pointer-events: none;
            transform-origin: left top;
            transition: top 0.2s cubic-bezier(0.4,0,0.2,1), transform 0.2s cubic-bezier(0.4,0,0.2,1), color 0.2s;
            white-space: nowrap;
            margin: 0;
            padding: 0;
        }
        div.search-wrapper .school-input-wrapper.floating > label {
            top: -1px !important;
            transform: scale(0.75) !important;
        }
        .school-input-wrapper > label svg {
            transition: width 0.2s cubic-bezier(0.4,0,0.2,1), height 0.2s cubic-bezier(0.4,0,0.2,1);
        }
        .school-input-wrapper.focused > label svg,
        .school-input-wrapper.floating > label svg {
            width: 12px;
            height: 12px;
        }
        div.search-wrapper .school-input-wrapper.focused > label {
            color: #1976d2;
        }
        div.search-wrapper .school-input-wrapper > input.form-control {
            font-size: 14px !important;
            line-height: 1.5 !important;
            height: auto !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }
        .school-input-wrapper > input.form-control::placeholder {
            color: transparent !important;
            opacity: 0 !important;
            transition: color 0.2s, opacity 0.2s;
        }
        .school-input-wrapper > input.form-control:focus::placeholder {
            color: rgba(0,0,0,0.42) !important;
            opacity: 1 !important;
        }
        .school-search-results {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid #ccc;
            border-top: none;
            border-radius: 0 0 4px 4px;
            max-height: 250px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .school-search-results.active {
            display: block;
        }
        .school-search-results a {
            display: block;
            padding: 0.35rem 0.6rem;
            color: #333;
            text-decoration: none;
            font-size: 0.85rem;
            border-bottom: 1px solid #f0f0f0;
        }
        .school-search-results a:hover,
        .school-search-results a.highlighted {
            background: #e9ecef;
        }
        .school-search-results .no-results {
            padding: 0.35rem 0.6rem;
            color: #999;
            font-size: 0.85rem;
            font-style: italic;
        }
        #beta-paywall-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0, 0, 0, 0.55);
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        #beta-paywall-card {
            width: 100%;
            max-width: 36rem;
            background: #fff;
            border: 1px solid #cfd3dc;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
            padding: 1.25rem;
            text-align: center;
        }
        #beta-paywall-card h2 {
            margin-top: 0;
            margin-bottom: 0.75rem;
        }
        #beta-paywall-card p {
            margin-bottom: 1rem;
        }
    </style>
    <!-- END -->

    <header class="jumbotron jumbotron-fluid results-index bg-primary">
        <div class="container">
            <h1 class="text-light text-center">
                <a href="/">
                    Triosmium
                </a>
            </h1>
            <p class="lead text-light text-center">Powered by
                <a href="https://github.com/Duosmium/sciolyff">SciolyFF
                    <svg id="GitHub" role="img" viewBox="0 0 24 24" width="24" height="24">
                        <title>GitHub</title>
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" style="fill: #f5f5f5"/>
                    </svg>
                </a>
            </p>
        </div>
    </header>

    <div class="container py-5">
        <div class="form-group">
            <div class="floating-label floating-label-lg">
                <div id="searchTournamentsContainer" class="d-flex flex-nowrap align-items-center">
                    <label for="searchTournaments">
                        <svg id="search" role="img" width="24" height="24" viewBox="0 0 24 24">
                            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                            <path d="M0 0h24v24H0z" fill="none"/>
                        </svg>
                        <i>Search tournaments</i>
                    </label>
                    <input aria-describedby="searchTournamentsHelp" class="form-control" id="searchTournaments" type="text" placeholder="e.g. nats div c 2017" autocomplete="off">
                    <button id="searchTournamentsClear" class="close" type="button" aria-label="Close">
                        <span aria-hidden="true">&times;</span></button>
                </div>
                <span id="searchTournamentsHelp" class="form-text text-muted">
                    Find the overall standings and event scores for thousands of Science Olympiad tournaments!
                </span>
            </div>
        </div>
    </div>

    <div class="container" id="hide-on-search">
        <div class="row mt-3 pb-5 mb-5 justify-content-between">
            <div class="col-md-auto">
                <h2 class="h4">Recently added</h2>
                <ul class="recently-added">
                    {% for filename in recents.slice(0, 8) %}
                        {% set filename = filename.slice(0, -5) %}
                        {% set t = computed
                            .interpreters[computed.indices[filename]][1]
                            .tournament %}
                        <li>
                            <a href="/results/{{ filename }}/" class="full-results">
                                {{ t.year }}
                                {{ helpers.tournamentTitleShort(t) }} (Div.&nbsp;{{ t.division }})</a>
                            {% if official
                                .all
                                .includes(filename) %}
                                <span class="badge official">
                                    <small>Official</small>
                                </span>
                            {% endif %}
                            {% if preliminary.includes(filename) %}
                                <span class="badge preliminary">
                                    <small>Preliminary</small>
                                </span>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
                <h2 class="h4">Upcoming</h2>
                {% set upcoming_count = 0 %}
                {% for date, tournaments in upcoming %}
                    <h3 class="h5">{{ date }}</h3>
                    <ul>
                        {% for t in tournaments | sort(false, false, "name") %}
                            {{ "<s>" if t.cancelled else "" }}
                            <li>
                                <a href="{{ t.link }}">{{ t.name | replace("(Div. ", "(Div.&nbsp;") | safe }}</a>
                                {% if t
                                    .official or official
                                    .all
                                    .includes(t.file) %}
                                    <span class="badge official">
                                        <small>Official</small>
                                    </span>
                                {% endif %}
                            </li>
                            {% set upcoming_count = upcoming_count + 1 %}
                            {{ "</s>" if t.cancelled else "" }}
                        {% endfor %}
                    </ul>
                {% endfor %}
                {% if upcoming_count === 0 %}
                    <p>No tournaments coming up... for now.</p>
                {% endif %}
            </div>
            <div class="col-md-auto results-sidebar">
                <div class="school-search-bar">
                    <div class="school-input-wrapper">
                        <label for="school-nav-search">
                            <svg role="img" width="14" height="14" viewBox="0 0 24 24">
                                <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                                <path d="M0 0h24v24H0z" fill="none"/>
                            </svg>
                            <i>Search schools</i>
                        </label>
                        <input type="text" class="form-control" id="school-nav-search" placeholder="e.g. San Diego" autocomplete="off" />
                    </div>
                    <div class="school-search-results" id="school-nav-results"></div>
                </div>
                <h2 class="h4">Archive Totals</h2>
                <dl>
                    <dt>{{ computed.counts.nationals }}</dt>
                    <dd>National Tournaments</dd>
                    <dt>{{ computed.counts.states }}</dt>
                    <dd>State Tournaments</dd>
                    <dt>{{ computed.counts.regionals }}</dt>
                    <dd>Regionals</dd>
                    <dt>{{ computed.counts.invitational }}</dt>
                    <dd>Invitationals</dd>
                    <dt>{{ computed.counts.total }}</dt>
                    <dd>Total</dd>
                </dl>
                <b>
                    <a href="https://scoring.duosmium.org/">Use our new free web-based scoring system!</a>
                </b>
                <br>
                <br>
                <a href="/input-template">Help contribute!</a>
                <br>
                <a href="https://blog.duosmium.org">Visit our blog!</a>
                <br>
                <a href="https://discord.gg/D6H5KNScHB">Join us on Discord!</a>
            </div>
        </div>
    </div>
    <a href="#all" id="see-all"
     role="button" class="btn btn-flat-secondary btn-lg btn-block">See recent tournaments<br>
        <svg id="expand_more" role="img" width="24" height="24" viewBox="0 0 24 24">
            <path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z"/>
            <path d="M0 0h24v24H0z" fill="none"/>
        </svg>
    </a>
</div>

<main id="all" class="container-fluid pt-4 pb-5 bg-light-3 shadow" aria-label="Content">
    <div class="results-index-card-grid">
        {% for filename, i in computed
            .interpreters
            .slice(0, 24) %}
            {% set teams = i.teams %}
            <div class="card">
                <div class="card-header text-light shadow-sm"
                     style="background-color: {{helpers.findBgColor(filename) | await}}"
                >
                    <h2 class="card-title">
                        {{ i.tournament.year }}
                        {{ helpers.tournamentTitle(i.tournament) }}
                        <span class="badge division-{{ i.tournament.division | lower }}">
                            <small>Division {{ i.tournament.division }}</small>
                        </span>
                        {% if official
                            .all
                            .includes(filename) %}
                            <span class="badge official">
                                <small>Official</small>
                            </span>
                        {% endif %}
                        {% if preliminary.includes(filename) %}
                            <span class="badge preliminary">
                                <small>Preliminary</small>
                            </span>
                        {% endif %}
                    </h2>
                    <h3 class="card-subtitle">
                        {% if helpers.fmtDate(i.tournament.startDate) === helpers.fmtDate(i.tournament.endDate) %}
                            {{ helpers.fmtDate(i.tournament.startDate) }}
                        {% else %}
                            {{ helpers.fmtDate(i.tournament.startDate) }} - {{ helpers.fmtDate(i.tournament.endDate) }}
                        {% endif %}
                        <br>@ {{ i.tournament.location }}
                    </h3>
                </div>
                <div class="card-body splash-wrapper"
                     data-toggle="collapse"
                     data-target="#summary-{{ filename }}"
                     aria-expanded="false"
                     aria-controls="summary-{{ filename }}"
                >
                    <img class="lazy"
                         data-src="{{ helpers.findLogoPath(filename) }}"
                         alt="Tournament logo"/>
                    <div class="summary collapse" id="summary-{{ filename }}">
                        <dl class="list-unstyled row">
                            {% for summaryTitle in helpers.summaryTitles %}
                                {% if teams[loop.index0] %}
                                    <dt class="col-sm-3 {{ 'd-none d-sm-block' if i >= 3 else '' }}">
                                        {{ summaryTitle }}
                                    </dt>
                                    <dd class="col-sm-9 {{ 'd-none d-sm-block' if i >= 3 else '' }}">
                                        {{ helpers.formatSchool(teams[loop.index0]) }}
                                        {{ teams[loop.index0].suffix }}
                                        <small>{{ teams[loop.index0].state }}</small>
                                    ({{ teams[loop.index0].points }} pts)
                                    </dd>
                                {% endif %}
                            {% endfor %}
                        </dl>
                    </div>
                </div>
                <div class="card-footer card-actions bg-light">
                    <button class="btn btn-outline-primary summary">Summary</button>
                    <a href="/results/{{ filename }}/" class="btn btn-outline-primary full-results">Full Results</a>
                    <span class="badge badge-dark teams-count">
                        {{ i.tournament.nonExhibitionTeamsCount }} Teams
                    </span>
                </div>
            </div>
        {% endfor %}
        <div class="grid-infobox">
            <button id="all-results">View all</button>
        </div>
    </div>
    <a href="#top" class="btn btn-float btn-light" id="scroll-back" role="button" aria-label="scroll to top">
        <svg id="expand_less" role="img" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 8l-6 6 1.41 1.41L12 10.83l4.59 4.58L18 14z"/>
            <path d="M0 0h24v24H0z" fill="none"/>
        </svg>
    </a>
</main>
<template id="card-template">
    <div class="card">
        <div class="card-header text-light shadow-sm"
        >
            <h2 class="card-title">
                <span data-slot="content"></span>
                <span data-slot="division" class="badge">
                    <small data-slot="division"></small>
                </span>
                <span class="badge official">
                    <small>Official</small>
                </span>
                <span class="badge preliminary">
                    <small>Preliminary</small>
                </span>
            </h2>
            <h3 class="card-subtitle">
                <span data-slot="date"></span>
                <br>@ <span data-slot="location"></span>
            </h3>
        </div>
        <div class="card-body splash-wrapper"
             data-toggle="collapse"
             data-target=""
             aria-expanded="false"
             aria-controls=""
        >
            <img class="lazy" alt="Tournament logo"/>
            <div class="summary collapse" id="">
                <dl class="list-unstyled row"></dl>
            </div>
        </div>
        <div class="card-footer card-actions bg-light">
            <button class="btn btn-outline-primary summary">Summary</button>
            <a href="" class="btn btn-outline-primary full-results">Full Results</a>
            <span class="badge badge-dark teams-count"></span>
        </div>
    </div>
</template>
<template id="summary-team">
    <dt class="col-sm-3"></dt>
    <dd class="col-sm-9">
        <span data-slot="content"></span>
        <small data-slot="state"></small>
        (<span data-slot="points"></span> pts)
    </dd>
</template>
{% include '_footer.njk' %}
<script>
    // This is the service worker with the combined offline experience (Offline page + Offline copy of pages)

    // Check compatibility for the browser we're running this in
    if ("serviceWorker" in navigator) {
        if (navigator.serviceWorker.controller) {
            console.log("[PWA Builder] active service worker found, no need to register");
        } else {
            // Register the service worker
            navigator
                .serviceWorker
                .register("/results/pwabuilder-sw.js", {scope: "/results/"})
                .then(function (reg) {
                    console.log("[PWA Builder] Service worker has been registered for scope: " + reg.scope);
                });
        }
    }
</script>
<script>
    (function() {
        var path = window.location.pathname;
        var onlyRoot = path === '/results/' || path === '/results' || path === '/results/index.html' || path === '/' || path === '/index.html';
        if (!onlyRoot) return;

        var dismissedKey = 'triosmiumBetaPaywallDismissed';
        try {
            if (sessionStorage.getItem(dismissedKey) === '1') return;
        } catch (e) {
            // If sessionStorage is unavailable, still show overlay for this page load.
        }

        var overlay = document.getElementById('beta-paywall-overlay');
        var continueButton = document.getElementById('beta-paywall-continue');
        if (!overlay || !continueButton) return;

        overlay.style.display = 'flex';
        overlay.setAttribute('aria-hidden', 'false');

        continueButton.addEventListener('click', function() {
            try {
                sessionStorage.setItem(dismissedKey, '1');
            } catch (e) {
                // Ignore storage write failures.
            }
            overlay.style.display = 'none';
            overlay.setAttribute('aria-hidden', 'true');
        });
    })();
</script>
<script>
    (function() {
        var navInput = document.getElementById('school-nav-search');
        var navResults = document.getElementById('school-nav-results');
        if (!navInput || !navResults) return;

        // Floating label management
        var navWrapper = navInput.closest('.school-input-wrapper');
        function updateNavFloat() {
            navWrapper.classList.toggle('floating', navInput.value.length > 0);
        }
        navInput.addEventListener('focus', function() {
            navWrapper.classList.add('focused', 'floating');
        });
        navInput.addEventListener('blur', function() {
            navWrapper.classList.remove('focused');
            updateNavFloat();
        });
        navInput.addEventListener('input', updateNavFloat);

        var schoolNames = null;
        var navHighlight = -1;
        var navItems = [];

        function loadSchoolNames(cb) {
            if (schoolNames) { cb(); return; }
            var xhr = new XMLHttpRequest();
            xhr.open('GET', '/cache/school-names.json');
            xhr.onload = function() {
                if (xhr.status === 200) {
                    schoolNames = JSON.parse(xhr.responseText);
                }
                cb();
            };
            xhr.onerror = function() { cb(); };
            xhr.send();
        }

        function showResults(query) {
            navResults.innerHTML = '';
            navHighlight = -1;
            navItems = [];
            if (!schoolNames || query.length < 2) {
                navResults.classList.remove('active');
                return;
            }
            var lower = query.toLowerCase();
            var matches = [];
            for (var i = 0; i < schoolNames.length && matches.length < 20; i++) {
                if (schoolNames[i].toLowerCase().indexOf(lower) !== -1) {
                    matches.push(schoolNames[i]);
                }
            }
            if (matches.length === 0) {
                var noR = document.createElement('div');
                noR.className = 'no-results';
                noR.textContent = 'No schools found';
                navResults.appendChild(noR);
            } else {
                for (var j = 0; j < matches.length; j++) {
                    var a = document.createElement('a');
                    a.href = '/results/school/' + matches[j].replace(/ /g, '_') + '/';
                    a.textContent = matches[j];
                    navResults.appendChild(a);
                    navItems.push(a);
                }
            }
            navResults.classList.add('active');
        }

        function setHighlight(idx) {
            if (navItems[navHighlight]) navItems[navHighlight].classList.remove('highlighted');
            navHighlight = idx;
            if (navItems[navHighlight]) {
                navItems[navHighlight].classList.add('highlighted');
                navItems[navHighlight].scrollIntoView({ block: 'nearest' });
            }
        }

        var navTimeout;
        navInput.addEventListener('input', function() {
            clearTimeout(navTimeout);
            navTimeout = setTimeout(function() {
                loadSchoolNames(function() { showResults(navInput.value.trim()); });
            }, 150);
        });

        navInput.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (navItems.length > 0) setHighlight(Math.min(navHighlight + 1, navItems.length - 1));
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (navItems.length > 0) setHighlight(Math.max(navHighlight - 1, 0));
            } else if (e.key === 'Enter') {
                e.preventDefault();
                if (navHighlight >= 0 && navItems[navHighlight]) {
                    window.location.href = navItems[navHighlight].href;
                }
            } else if (e.key === 'Escape') {
                navResults.classList.remove('active');
            }
        });

        document.addEventListener('click', function(e) {
            if (!navInput.contains(e.target) && !navResults.contains(e.target)) {
                navResults.classList.remove('active');
            }
        });

        navInput.addEventListener('focus', function() {
            if (navInput.value.trim().length >= 2 && navItems.length > 0) {
                navResults.classList.add('active');
            }
        });
    })();
</script>
