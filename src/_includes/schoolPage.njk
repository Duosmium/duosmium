{% extends "base.njk" %}
{% block head %}
    <link href="/main.css" rel="stylesheet"/>
    <style>
        .school-header {
            text-align: center;
            padding: 1rem 0 0.5rem;
        }
        .school-header h1 {
            font-size: 1.5rem;
            margin: 0;
        }
        .school-header h1 a {
            color: inherit;
            text-decoration: none;
        }
        .school-infobox {
            background: #fff;
            border-radius: 12px;
            padding: 2rem 2.5rem;
            margin: 0 auto 2rem;
            max-width: 720px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.05);
            border: 1px solid rgba(0,0,0,0.06);
            text-align: center;
        }
        .school-infobox h2 {
            font-size: 2.2rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.01em;
        }
        .school-infobox .school-division {
            font-size: 0.85rem;
            color: #888;
            font-weight: 500;
            margin-left: 0.3rem;
        }
        .school-infobox .school-location {
            font-size: 1rem;
            color: #666;
            margin: 0.25rem 0 0.75rem;
        }
        .school-infobox .stats-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            justify-content: center;
        }
        .school-infobox .stat-card {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 0.6rem 1.2rem;
            text-align: center;
            min-width: 120px;
            border: 1px solid #e9ecef;
        }
        .stat-card .stat-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #888;
            font-weight: 600;
        }
        .stat-card .stat-value {
            font-size: 1.4rem;
            font-weight: 700;
            color: #333;
            line-height: 1.3;
        }
        .school-infobox .best-section {
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #eee;
        }
        .school-infobox .best-section h3 {
            font-size: 0.95rem;
            font-weight: 600;
            color: #666;
            margin: 0 0 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .school-infobox .best-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            justify-content: center;
        }
        .school-infobox .best-card {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 0.75rem 1.2rem;
            text-align: center;
            min-width: 120px;
            border: 1px solid #e9ecef;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.12rem;
        }
        .best-card .best-level {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #888;
            font-weight: 600;
        }
        .best-card .best-rank {
            display: inline-flex;
            align-items: baseline;
            justify-content: center;
            gap: 0.35rem;
            line-height: 1.05;
            margin-top: 0.1rem;
        }
        .best-card .best-rank-main {
            font-size: 1.55rem;
            font-weight: 750;
            color: #2d2d2d;
            letter-spacing: -0.01em;
        }
        .best-card .best-rank-count {
            font-size: 0.72rem;
            font-weight: 600;
            color: #8f8f8f;
            letter-spacing: 0.01em;
            line-height: 1;
            transform: translateY(-1px);
        }
        .best-card .best-seasons {
            font-size: 0.7rem;
            color: #aaa;
        }
        .school-filters-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-bottom: 1rem;
            align-items: center;
            justify-content: space-between;
        }
        .school-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            align-items: center;
        }
        .school-filters label {
            font-weight: 500;
            margin: 0;
            font-size: 0.9rem;
        }
        .school-filters select {
            font-size: 0.9rem;
        }
        .school-search {
            display: flex;
            align-items: center;
        }
        .school-search input {
            font-size: 0.9rem;
            padding: 0.25rem 0.5rem;
            border: 1px solid #ced4da;
            border-radius: 4px;
            width: 220px;
        }
        tr.school-row-hidden {
            display: none;
        }
        #school-results-table th {
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }
        #school-results-table th .sort-arrow {
            font-size: 0.7em;
            margin-left: 3px;
            opacity: 0.3;
        }
        #school-results-table th.sort-asc .sort-arrow,
        #school-results-table th.sort-desc .sort-arrow {
            opacity: 1;
        }
        .col-date {
            min-width: 130px;
            white-space: nowrap;
        }
        .season-header-row td {
            background: #f0f2f4 !important;
            font-weight: 600;
            font-size: 0.75rem;
            padding: 0 !important;
            margin: 0 !important;
            height: 1.2em;
            border-bottom: 1px solid #e0e0e0;
            border-top: none !important;
            text-align: center;
            vertical-align: middle;
            color: #999;
            letter-spacing: 0.03em;
            line-height: 1;
        }
        .table-striped .season-header-row td,
        .table-striped tbody tr.season-header-row td {
            background: #f0f2f4 !important;
            padding: 0 !important;
        }
        .table-hover .season-header-row:hover {
            background-color: #f0f2f4 !important;
        }
        main.schools-index.container {
            max-width: 1200px;
        }
        .total-teams-sub {
            color: #999;
            font-weight: 400;
            font-size: 0.85em;
        }
        .results-section-header {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 1rem;
        }
        .results-section-header h3 {
            font-size: 1.3rem;
            font-weight: 700;
            margin: 0;
        }
        .condensed-toggle {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.85rem;
            color: #666;
            cursor: pointer;
            user-select: none;
        }
        .condensed-toggle input { display: none; }
        .toggle-slider {
            width: 34px;
            height: 18px;
            background: #ccc;
            border-radius: 9px;
            position: relative;
            transition: background 0.2s;
        }
        .toggle-slider::after {
            content: '';
            position: absolute;
            width: 14px;
            height: 14px;
            background: #fff;
            border-radius: 50%;
            top: 2px;
            left: 2px;
            transition: transform 0.2s;
        }
        .condensed-toggle input:checked + .toggle-slider {
            background: #007bff;
        }
        .condensed-toggle input:checked + .toggle-slider::after {
            transform: translateX(16px);
        }
        #condensed-view { display: none; }
        #condensed-view.active { display: block; }
        #full-view.hidden { display: none; }
        .condensed-div-label {
            font-size: 1rem;
            font-weight: 600;
            color: #555;
            margin: 1.25rem 0 0.4rem;
        }
        .condensed-table {
            width: 100%;
            margin-bottom: 1.5rem;
        }
        .condensed-table th {
            font-size: 0.85rem;
        }
        .condensed-table td {
            font-size: 0.9rem;
        }
        .condensed-table td a {
            color: inherit;
            text-decoration: none;
            border-bottom: 1px dotted #bbb;
        }
        .condensed-table td a:hover {
            color: #007bff;
            border-bottom-color: #007bff;
        }
        .event-results-section {
            margin-top: 2.5rem;
        }
        .event-results-section .results-section-header {
            margin-bottom: 1rem;
        }
        .event-results-table th {
            white-space: nowrap;
            font-size: 0.8rem;
            vertical-align: bottom;
        }
        .event-results-table th a {
            color: #fff;
            text-decoration: underline;
        }
        .event-results-table td {
            font-size: 0.85rem;
            white-space: nowrap;
        }
        .event-results-table .event-name-cell {
            font-weight: 500;
            white-space: normal;
            min-width: 150px;
        }
        .medal-place {
            padding: 0.05rem 0.3rem;
            border-radius: 3px;
        }
        .event-summary-row td {
            background: #f8f9fa !important;
            font-weight: 600;
        }
        .event-div-label {
            font-size: 1rem;
            font-weight: 600;
            color: #555;
            margin: 1.25rem 0 0.4rem;
        }
        #event-season-select {
            font-size: 0.9rem;
        }
        .section-collapse-btn {
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
            font-size: 1.1rem;
            color: #888;
            line-height: 1;
            transition: transform 0.2s;
        }
        .section-collapse-btn.collapsed {
            transform: rotate(-90deg);
        }
        #school-results-body.collapsed,
        #event-results-body.collapsed {
            display: none;
        }
        .status-text {
            font-size: 0.75rem;
            color: #aaa;
            font-style: italic;
        }
        .school-search-bar {
            position: relative;
            max-width: 400px;
            margin: 0.5rem 0 1rem auto;
        }
        .school-search-bar input {
            width: 100%;
            padding: 0.4rem 0.6rem;
            font-size: 0.9rem;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        .school-search-bar input:focus {
            outline: none;
            border-color: #007bff;
            box-shadow: 0 0 0 2px rgba(0,123,255,0.15);
        }
        .school-search-results {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid #ccc;
            border-top: none;
            border-radius: 0 0 4px 4px;
            max-height: 250px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .school-search-results.active {
            display: block;
        }
        .school-search-results a {
            display: block;
            padding: 0.35rem 0.6rem;
            color: #333;
            text-decoration: none;
            font-size: 0.85rem;
            border-bottom: 1px solid #f0f0f0;
        }
        .school-search-results a:hover,
        .school-search-results a.highlighted {
            background: #e9ecef;
        }
        .school-search-results .no-results {
            padding: 0.35rem 0.6rem;
            color: #999;
            font-size: 0.85rem;
            font-style: italic;
        }
        .h2h-selector {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            margin: 0 auto 1.4rem;
            max-width: 720px;
            padding: 0.35rem 0 0.9rem;
            border-bottom: 1px solid #e9edf2;
        }
        .h2h-selector-title {
            margin: 0;
            font-size: 0.84rem;
            font-weight: 600;
            color: #6b7784;
            letter-spacing: 0.01em;
            text-transform: none;
        }
        .h2h-selector-input-wrap {
            position: relative;
            width: min(460px, 100%);
        }
        .h2h-selector-input-wrap input {
            width: 100%;
            padding: 0.38rem 0.6rem;
            font-size: 0.9rem;
            border: 1px solid #ccd5df;
            border-radius: 4px;
            background: #fff;
        }
        .h2h-selector-results {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid #ccd5df;
            border-top: none;
            border-radius: 0 0 4px 4px;
            max-height: 250px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .h2h-selector-results.active {
            display: block;
        }
        .h2h-selector-results a,
        .h2h-selector-results .no-results {
            display: block;
            padding: 0.35rem 0.6rem;
            color: #333;
            text-decoration: none;
            font-size: 0.85rem;
            border-bottom: 1px solid #f0f0f0;
        }
        .h2h-selector-results a:hover,
        .h2h-selector-results a.highlighted {
            background: #e9ecef;
        }
        @media (max-width: 767px) {
            .h2h-selector {
                flex-direction: column;
                align-items: stretch;
                gap: 0.4rem;
            }
            .h2h-selector-title {
                font-size: 0.82rem;
            }
            .h2h-selector-input-wrap {
                width: 100%;
            }
        }
    </style>
{% endblock %}
{% block script %}
    <script src="/main.js"></script>
{% endblock %}
{% block content %}
<header class="schools-index jumbotron jumbotron-fluid bg-primary mb-3">
    <div class="container school-header">
        <h1 class="text-light">
            <a href="/results/">Duosmium Results</a>
        </h1>
    </div>
</header>

<main class="schools-index container">
    <p>
        <a href="/results/schools/{{ data.school[0] | lower }}/">&#8592; Back to Schools List</a>
    </p>

    <div class="school-search-bar">
        <input type="text" id="school-nav-search" placeholder="Search schools" autocomplete="off" />
        <div class="school-search-results" id="school-nav-results"></div>
    </div>

    <div class="school-infobox">
        <h2>{{ data.school }}<span class="school-division">Division {{ data.divisions | join("/") }}</span></h2>
        <div class="school-location">{{ data.city }}{% if data.city and data.stateFull %}, {% endif %}{{ data.stateFull }}</div>
        <div class="stats-grid">
            {% if data.oldestSeason %}
                <div class="stat-card">
                    <div class="stat-label">Competing Since</div>
                    <div class="stat-value">{{ data.oldestSeason }}</div>
                </div>
            {% endif %}
            <div class="stat-card">
                <div class="stat-label">Tournaments</div>
                <div class="stat-value">{{ data.totalTournaments }}</div>
            </div>
        </div>
        {% if data.bestPlacements %}
            <div class="best-section">
                <h3>Best Placements</h3>
                <div class="best-grid">
                    {% if data.bestPlacements.Invitational %}
                        <div class="best-card">
                            <div class="best-level">Invitational</div>
                            <div class="best-rank">
                                <span class="best-rank-main">{{ data.bestPlacements.Invitational.rank }}</span>
                                {% if data.bestPlacements.Invitational.count > 1 %}<span class="best-rank-count">({{ data.bestPlacements.Invitational.count }}x)</span>{% endif %}
                            </div>
                            <div class="best-seasons">{{ data.bestPlacements.Invitational.seasonsDisplay }}</div>
                        </div>
                    {% endif %}
                    {% if data.bestPlacements.Regional %}
                        <div class="best-card">
                            <div class="best-level">Regional</div>
                            <div class="best-rank">
                                <span class="best-rank-main">{{ data.bestPlacements.Regional.rank }}</span>
                                {% if data.bestPlacements.Regional.count > 1 %}<span class="best-rank-count">({{ data.bestPlacements.Regional.count }}x)</span>{% endif %}
                            </div>
                            <div class="best-seasons">{{ data.bestPlacements.Regional.seasonsDisplay }}</div>
                        </div>
                    {% endif %}
                    {% if data.bestPlacements.State %}
                        <div class="best-card">
                            <div class="best-level">State</div>
                            <div class="best-rank">
                                <span class="best-rank-main">{{ data.bestPlacements.State.rank }}</span>
                                {% if data.bestPlacements.State.count > 1 %}<span class="best-rank-count">({{ data.bestPlacements.State.count }}x)</span>{% endif %}
                            </div>
                            <div class="best-seasons">{{ data.bestPlacements.State.seasonsDisplay }}</div>
                        </div>
                    {% endif %}
                    {% if data.bestPlacements.National %}
                        <div class="best-card">
                            <div class="best-level">National</div>
                            <div class="best-rank">
                                <span class="best-rank-main">{{ data.bestPlacements.National.rank }}</span>
                                {% if data.bestPlacements.National.count > 1 %}<span class="best-rank-count">({{ data.bestPlacements.National.count }}x)</span>{% endif %}
                            </div>
                            <div class="best-seasons">{{ data.bestPlacements.National.seasonsDisplay }}</div>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>

    <div class="h2h-selector">
        <div class="h2h-selector-title">Head-To-Head Comparison</div>
        <div class="h2h-selector-input-wrap">
            <input type="text" id="h2h-school-search" placeholder="Compare to another school" autocomplete="off" />
            <div class="h2h-selector-results" id="h2h-school-results"></div>
        </div>
    </div>

    {% if data.results.length > 0 %}
        <div class="results-section-header">
            <button class="section-collapse-btn" id="school-results-toggle" aria-label="Toggle School Results">&#9660;</button>
            <h3>School Results</h3>
            <label class="condensed-toggle">
                <input type="checkbox" id="condensed-check" />
                <span class="toggle-slider"></span>
                Condensed
            </label>
        </div>

        <div id="school-results-body">

        <div id="full-view">
        <div class="school-filters-bar">
            <div class="school-filters">
                <div>
                    <label for="filter-type">Level:</label>
                    <select id="filter-type" class="custom-select custom-select-sm" style="width: auto;">
                        <option value="all" selected>All</option>
                        <option value="Invitational">Invitational</option>
                        <option value="Regional">Regional</option>
                        <option value="State">State</option>
                        <option value="National">National</option>
                    </select>
                </div>
                <div>
                    <label for="filter-season">Season:</label>
                    <select id="filter-season" class="custom-select custom-select-sm" style="width: auto;">
                        <option value="all" selected>All</option>
                        {% for s in data.seasonsList %}
                            <option value="{{ s }}">{{ s }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="filter-division">Division:</label>
                    <select id="filter-division" class="custom-select custom-select-sm" style="width: auto;">
                        <option value="all" selected>All</option>
                        {% for d in data.divisions %}
                            <option value="{{ d }}">Division {{ d }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="school-search">
                <input type="text" id="search-tournament" placeholder="Search by tournament..." />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover" id="school-results-table">
                <thead class="thead-dark">
                    <tr>
                        <th data-col="0" data-type="date">Date <span class="sort-arrow">&#9650;</span></th>
                        <th data-col="1" data-type="num">Season <span class="sort-arrow">&#9650;</span></th>
                        <th data-col="2" data-type="text">Tournament <span class="sort-arrow">&#9650;</span></th>
                        <th data-col="3" data-type="level">Level <span class="sort-arrow">&#9650;</span></th>
                        <th data-col="4" data-type="text">Team Name <span class="sort-arrow">&#9650;</span></th>
                        <th data-col="5" data-type="num">Points <span class="sort-arrow">&#9650;</span></th>
                        <th data-col="6" data-type="rank">Rank <span class="sort-arrow">&#9650;</span></th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in data.results %}
                        <tr class="data-row" data-level="{{ r.level }}" data-season="{{ r.season }}" data-division="{{ r.division }}" data-date="{{ r.tournamentDateISO }}" data-keywords="{{ r.keywords }}" data-rank="{{ r.rank }}" data-filename="{{ r.filename }}" data-trophies="{{ r.trophies }}">
                            <td class="col-date">{{ r.tournamentDateFmt }}</td>
                            <td>{{ r.season }}</td>
                            <td>
                                <a href="/results/{{ r.filename }}/">
                                    {{ r.tournamentName }}
                                </a>
                            </td>
                            <td>{{ r.level }}</td>
                            <td>{{ r.teamName }}</td>
                            <td>{{ r.points }}</td>
                            <td>{{ r.rankOrdinal }}<span class="total-teams-sub">/{{ r.totalTeams }}</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        </div>
        </div>
    {% else %}
        <p>No tournament results found for this school.</p>
    {% endif %}

    <div class="event-results-section">
        <div class="results-section-header">
            <button class="section-collapse-btn" id="event-results-toggle" aria-label="Toggle Event Results">&#9660;</button>
            <h3>Event Results</h3>
            <select id="event-season-select" class="custom-select custom-select-sm" style="width: auto;"></select>
        </div>
        <div id="event-results-body">
            <div id="event-results-container"></div>
        </div>
    </div>

    <a href="#top" class="btn btn-float btn-light" id="scroll-back" role="button" aria-label="scroll to top">
        <svg id="expand_less" role="img" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 8l-6 6 1.41 1.41L12 10.83l4.59 4.58L18 14z"/>
            <path d="M0 0h24v24H0z" fill="none"/>
        </svg>
    </a>
</main>
{% include '_footer.njk' %}
<script>
(function() {
    var medalColors = [
        '#FFF176','#E0E0E0','#BCAAA4','#FFECB3','#C5E1A5',
        '#E1BEE7','#FFE0B2','#B2EBF2','#F8BBD0','#D1C4E9',
        '#EEEEEE','#EEEEEE','#EEEEEE','#EEEEEE','#EEEEEE',
        '#F5F5F5','#F5F5F5','#F5F5F5','#F5F5F5','#F5F5F5'
    ];

    var table = document.getElementById('school-results-table');
    if (table) {
    var tbody = table.querySelector('tbody');
    var headers = table.querySelectorAll('thead th');
    var typeFilter = document.getElementById('filter-type');
    var seasonFilter = document.getElementById('filter-season');
    var divisionFilter = document.getElementById('filter-division');
    var searchInput = document.getElementById('search-tournament');
    var colCount = headers.length;
    var currentSortCol = 0;
    var currentSortDir = 'desc';

    var levelOrder = { 'Invitational': 0, 'Regional': 1, 'State': 2, 'National': 3 };

    var stateAbbrs = {
        al:['alabama'],ak:['alaska'],az:['arizona'],ar:['arkansas'],ca:['california'],
        nca:['northern','california'],sca:['southern','california'],co:['colorado'],
        ct:['connecticut'],de:['delaware'],dc:['district','columbia'],fl:['florida'],
        ga:['georgia'],hi:['hawaii'],id:['idaho'],il:['illinois'],in:['indiana'],
        ia:['iowa'],ks:['kansas'],ky:['kentucky'],la:['louisiana'],me:['maine'],
        md:['maryland'],ma:['massachusetts'],mi:['michigan'],mn:['minnesota'],
        ms:['mississippi'],mo:['missouri'],mt:['montana'],ne:['nebraska'],
