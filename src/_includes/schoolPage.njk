            });

            h2hInput.addEventListener('focus', function() {
                if (h2hInput.value.trim().length >= 2 && h2hItems.length > 0) {
                    h2hResults.classList.add('active');
                }
            });

            document.addEventListener('click', function(e) {
                if (!h2hInput.contains(e.target) && !h2hResults.contains(e.target)) {
                    h2hResults.classList.remove('active');
                }
            });
        }
    }
})();
</script>
{% endblock %}
