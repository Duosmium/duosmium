    function expandSearchWords(text) {
        var normalized = text.toLowerCase().trim()
            .replace(/(div|division) ([abc])/, '$1-$2')
            .replace(/\s([abc])(?:\s|$)/, ' div-$1 ');
        var raw = normalized.split(/[^\w-]+/).filter(function(w) { return w.length > 0; });
        var words = [];
        for (var i = 0; i < raw.length; i++) {
            if (stateAbbrs[raw[i]]) {
                words = words.concat(stateAbbrs[raw[i]]);
            } else {
                words.push(raw[i]);
            }
        }
        return words;
    }

    function matchesSearch(keywords, words) {
        if (words.length === 0) return true;
        var kws = keywords.split(' ');
        for (var i = 0; i < words.length; i++) {
            var found = false;
            for (var j = 0; j < kws.length; j++) {
                if (kws[j].indexOf(words[i]) === 0) { found = true; break; }
            }
            if (!found) return false;
        }
        return true;
    }

    function insertSeasonHeaders() {
        var old = tbody.querySelectorAll('.season-header-row');
        for (var i = 0; i < old.length; i++) old[i].remove();

        var rows = tbody.querySelectorAll('.data-row');
        var seasonFiles = {};
        for (var i = 0; i < rows.length; i++) {
            var row = rows[i];
            if (row.classList.contains('school-row-hidden')) continue;
            var season = row.getAttribute('data-season');
            var fn = row.getAttribute('data-filename');
            if (!seasonFiles[season]) seasonFiles[season] = {};
            seasonFiles[season][fn] = true;
        }

        var lastSeason = null;
        for (var i = 0; i < rows.length; i++) {
            var row = rows[i];
            if (row.classList.contains('school-row-hidden')) continue;
            var season = row.getAttribute('data-season');
            if (season !== lastSeason) {
                lastSeason = season;
                var cnt = Object.keys(seasonFiles[season] || {}).length;
                var hdr = document.createElement('tr');
                hdr.className = 'season-header-row';
                hdr.setAttribute('data-season', season);
                var td = document.createElement('td');
                td.setAttribute('colspan', colCount);
                td.textContent = season + ' (' + cnt + ' tournament' + (cnt !== 1 ? 's' : '') + ')';
                hdr.appendChild(td);
                tbody.insertBefore(hdr, row);
            }
        }
    }

    function removeSeasonHeaders() {
        var old = tbody.querySelectorAll('.season-header-row');
        for (var i = 0; i < old.length; i++) old[i].remove();
    }

    function applyFilters() {
        var type = typeFilter.value;
        var season = seasonFilter.value;
        var division = divisionFilter.value;
        var searchWords = expandSearchWords(searchInput.value);
        var rows = tbody.querySelectorAll('.data-row');
        for (var i = 0; i < rows.length; i++) {
            var row = rows[i];
            var matchType = type === 'all' || row.getAttribute('data-level') === type;
            var matchSeason = season === 'all' || row.getAttribute('data-season') === season;
            var matchDiv = division === 'all' || row.getAttribute('data-division') === division;
            var kw = row.getAttribute('data-keywords') || '';
            var matchSearch = matchesSearch(kw, searchWords);
            if (matchType && matchSeason && matchDiv && matchSearch) {
                row.classList.remove('school-row-hidden');
            } else {
                row.classList.add('school-row-hidden');
            }
        }
        if (currentSortCol <= 1) {
            insertSeasonHeaders();
        } else {
            removeSeasonHeaders();
        }
    }

