    function getSortValue(row, col, type) {
        if (col === 0) return row.getAttribute('data-date') || '';
        if (col === 1) return parseInt(row.getAttribute('data-season')) || 0;
        if (type === 'rank') return parseInt(row.getAttribute('data-rank')) || 0;
        if (type === 'level') {
            var lv = row.getAttribute('data-level') || '';
            return levelOrder[lv] !== undefined ? levelOrder[lv] : -1;
        }
        var td = row.children[col];
        if (!td) return '';
        var text = td.textContent.trim();
        if (type === 'num') {
            var num = parseFloat(text.replace(/[^0-9.\-]/g, ''));
            return isNaN(num) ? 0 : num;
        }
        return text.toLowerCase();
    }

    function sortTable(colIdx) {
        var type = headers[colIdx].getAttribute('data-type');

        if (currentSortCol === colIdx) {
            currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
        } else {
            currentSortDir = (type === 'date' || type === 'num' || type === 'level') ? 'desc' : 'asc';
            currentSortCol = colIdx;
        }

        for (var i = 0; i < headers.length; i++) {
            headers[i].classList.remove('sort-asc', 'sort-desc');
            headers[i].querySelector('.sort-arrow').innerHTML = '&#9650;';
        }
        headers[colIdx].classList.add(currentSortDir === 'asc' ? 'sort-asc' : 'sort-desc');
        headers[colIdx].querySelector('.sort-arrow').innerHTML =
            currentSortDir === 'asc' ? '&#9650;' : '&#9660;';

        removeSeasonHeaders();

        var rows = Array.prototype.slice.call(tbody.querySelectorAll('.data-row'));
        rows.sort(function(a, b) {
            var va = getSortValue(a, colIdx, type);
            var vb = getSortValue(b, colIdx, type);
            var cmp = 0;
            if (typeof va === 'number' && typeof vb === 'number') {
                cmp = va - vb;
            } else {
                cmp = va < vb ? -1 : va > vb ? 1 : 0;
            }
            return currentSortDir === 'asc' ? cmp : -cmp;
        });

        for (var i = 0; i < rows.length; i++) {
            tbody.appendChild(rows[i]);
        }

        if (colIdx <= 1) {
            insertSeasonHeaders();
        }
    }

